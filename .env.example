# 应用环境
APP_ENV=development
LOG_LEVEL=info
LOG_DIR=./data/logs
DATA_DIR=./data
MYSQL_DSN=root:123456@tcp(127.0.0.1:3306)/bc_abe?charset=utf8mb4&parseTime=True&loc=Local

# Fabric
FABRIC_NETWORK_DIR=./pkg/fabric/test-network
FABRIC_BIN_DIR=./pkg/fabric/bin
CHANNEL_NAME=mychannel
CHAINCODE_NAME=abe_cc
# ccaas: 推荐，WSL2 下避免 peer 内 docker build；legacy: network.sh deployCC
CHAINCODE_DEPLOY=ccaas
FABRIC_CA_ORG1_URL=https://localhost:7054
FABRIC_CA_ORG2_URL=https://localhost:8054
FABRIC_CA_ADMIN_USER=admin
FABRIC_CA_ADMIN_PASS=adminpw
MSP_ID_ORG1=Org1MSP
MSP_ID_ORG2=Org2MSP
AUTH_NAME_ORG1=auth0
AUTH_NAME_ORG2=auth1
FABRIC_CONTAINERS=peer0.org1.example.com,peer0.org2.example.com,orderer.example.com,ca_org1,ca_org2,ca_orderer

# 服务端口
USER_CLIENT_PORT=8080
AUTH_ADMIN_ORG1_PORT=8091
AUTH_ADMIN_ORG2_PORT=8092

# ABE
ABE_SEED=bc-abe-demo-seed
